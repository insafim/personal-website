{
  "$schema": "https://biomejs.dev/schemas/2.3.0/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/.next",
      "!**/.velite",
      "!**/node_modules",
      "!**/coverage",
      "!**/playwright-report",
      "!**/dist",
      "!**/out",
      "!**/.vercel",
      "!**/.claude",
      "!**/.git",
      "!**/.github",
      "!**/public",
      "!**/scripts/**/*.py",
      "!**/content/**/*.mdx",
      "!**/content/**/*.yaml",
      "!**/pnpm-lock.yaml",
      "!**/next-env.d.ts",
      "!**/*.css"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "es5",
      "arrowParentheses": "always"
    }
  },
  "json": {
    "formatter": {
      "indentWidth": 2
    }
  },
  "css": {
    "formatter": {
      "enabled": false
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
